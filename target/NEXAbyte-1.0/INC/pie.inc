<script>
function togglePassword(inputId, btn) {
    var input = document.getElementById(inputId);
    if (input.type === 'password') {
        input.type = 'text';
        btn.innerHTML = '&#128064;';
        btn.setAttribute('aria-label', 'Ocultar contrase\u00f1a');
    } else {
        input.type = 'password';
        btn.innerHTML = '&#128065;';
        btn.setAttribute('aria-label', 'Mostrar contrase\u00f1a');
    }
    input.focus();
}

function validarYPrevisualizarAvatar(input) {
    var preview = document.getElementById('avatarPreviewImg');
    var MAX_SIZE = 100 * 1024; /* 100 KB */
    var TIPOS_VALIDOS = ['image/jpeg', 'image/png'];

    if (!input.files || !input.files[0]) return;

    var archivo = input.files[0];

    /* Validar tipo */
    if (TIPOS_VALIDOS.indexOf(archivo.type) === -1) {
        alert('Solo se permiten im\u00e1genes JPG o PNG.');
        input.value = '';
        return;
    }
    /* Validar tama\u00f1o */
    if (archivo.size > MAX_SIZE) {
        alert('La imagen no puede superar los 100 KB (tu archivo pesa ' + Math.round(archivo.size / 1024) + ' KB).');
        input.value = '';
        return;
    }
    /* Previsualizar */
    if (preview) {
        var reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
        };
        reader.readAsDataURL(archivo);
    }
    /* Des-seleccionar radios predefinidos al subir archivo */
    var radios = document.querySelectorAll('input[name="avatarPredefinido"]');
    for (var i = 0; i < radios.length; i++) {
        radios[i].checked = false;
    }
}

/* Al elegir un avatar predefinido, actualizar la preview y limpiar el file input */
document.addEventListener('DOMContentLoaded', function() {
    var radios = document.querySelectorAll('input[name="avatarPredefinido"]');
    var preview = document.getElementById('avatarPreviewImg');
    var fileInput = document.getElementById('avatarFile');
    for (var i = 0; i < radios.length; i++) {
        radios[i].addEventListener('change', function() {
            if (preview) {
                preview.src = this.closest('label').querySelector('img').src;
            }
            if (fileInput) {
                fileInput.value = '';
            }
        });
    }

    /* === Avatar radios del MODAL de registro === */
    var mRadios = document.querySelectorAll('#formModalRegistro input[name="avatarPredefinido"]');
    var mPreview = document.getElementById('m-avatarPreviewImg');
    var mFileInput = document.getElementById('m-avatarFile');
    for (var j = 0; j < mRadios.length; j++) {
        mRadios[j].addEventListener('change', function() {
            if (mPreview) {
                mPreview.src = this.closest('label').querySelector('img').src;
            }
            if (mFileInput) {
                mFileInput.value = '';
            }
        });
    }

    /* === NIF letra calculada mediante Ajax en modal registro === */
    var mNif = document.getElementById('m-nif');
    var mLetra = document.getElementById('m-letraNif');
    if (mNif) {
        mNif.addEventListener('input', function() {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (this.value.length === 8) {
                var xhr = new XMLHttpRequest();
                xhr.open('GET', 'Ajax?op=letraNif&nif=' + encodeURIComponent(this.value), true);
                xhr.onreadystatechange = function() {
                    if (xhr.readyState === 4 && xhr.status === 200) {
                        var data = JSON.parse(xhr.responseText);
                        mLetra.textContent = data.letra || '-';
                    }
                };
                xhr.send();
            } else {
                mLetra.textContent = '-';
            }
        });
    }

    /* === Email check en modal registro === */
    var mTel = document.getElementById('m-telefono');
    var mTelFb = document.getElementById('m-telefonoFeedback');
    if (mTel) {
        mTel.addEventListener('input', function() {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (this.value.length === 0) {
                mTelFb.textContent = ''; mTelFb.className = 'formulario-feedback';
            } else if (!/^[6789]/.test(this.value)) {
                mTelFb.textContent = '\u26A0 Debe empezar por 6, 7, 8 o 9';
                mTelFb.className = 'formulario-feedback feedback-invalido';
            } else if (this.value.length < 9) {
                mTelFb.textContent = '\u26A0 Debe tener 9 d\u00edgitos';
                mTelFb.className = 'formulario-feedback feedback-invalido';
            } else {
                mTelFb.textContent = '\u2713 Tel\u00e9fono v\u00e1lido';
                mTelFb.className = 'formulario-feedback feedback-valido';
            }
        });
    }

    var mEmail = document.getElementById('m-email');
    var mEmailFb = document.getElementById('m-emailFeedback');
    var mEmailTimer = null;
    if (mEmail) {
        mEmail.addEventListener('input', function() {
            var email = this.value.trim();
            clearTimeout(mEmailTimer);
            if (!email) { mEmailFb.textContent = ''; return; }
            var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!regex.test(email)) {
                mEmailFb.textContent = '\u26A0 Formato de email no v\u00e1lido';
                mEmailFb.className = 'formulario-feedback feedback-invalido';
                return;
            }
            mEmailTimer = setTimeout(function() {
                var xhr = new XMLHttpRequest();
                xhr.open('GET', 'GestionUsuario?op=comprobarEmail&email=' + encodeURIComponent(email), true);
                xhr.onreadystatechange = function() {
                    if (xhr.readyState === 4 && xhr.status === 200) {
                        var data = JSON.parse(xhr.responseText);
                        if (data.estado === 'existe') {
                            mEmailFb.textContent = '\u26A0 Este email ya est\u00e1 registrado';
                            mEmailFb.className = 'formulario-feedback feedback-invalido';
                        } else if (data.estado === 'disponible') {
                            mEmailFb.textContent = '\u2713 Email disponible';
                            mEmailFb.className = 'formulario-feedback feedback-valido';
                        }
                    }
                };
                xhr.send();
            }, 500);
        });
    }

    /* === SUBMIT modal Acceder (AJAX) === */
    var formAcceder = document.getElementById('formModalAcceder');
    if (formAcceder) {
        formAcceder.addEventListener('submit', function(e) {
            e.preventDefault();
            var errorDiv = document.getElementById('modalAccederError');
            var errorMsg = document.getElementById('modalAccederMsgError');
            errorDiv.style.display = 'none';

            var email = document.getElementById('m-login-email').value.trim();
            var pass = document.getElementById('m-login-password').value;

            if (!email || !pass) {
                errorMsg.textContent = 'Debes rellenar todos los campos.';
                errorDiv.style.display = 'block';
                return;
            }

            var xhr = new XMLHttpRequest();
            xhr.open('POST', 'GestionUsuario?op=acceder', true);
            xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
            xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
            xhr.onreadystatechange = function() {
                if (xhr.readyState === 4) {
                    if (xhr.status === 200) {
                        var data = JSON.parse(xhr.responseText);
                        if (data.resultado === 'ok') {
                            window.location.reload();
                        } else if (data.resultado === 'error') {
                            errorMsg.textContent = data.mensaje;
                            errorDiv.style.display = 'block';
                        }
                    } else {
                        errorMsg.textContent = 'Error de conexi\u00f3n. Int\u00e9ntalo de nuevo.';
                        errorDiv.style.display = 'block';
                    }
                }
            };
            xhr.send('email=' + encodeURIComponent(email) + '&password=' + encodeURIComponent(pass));
        });
    }

    /* === SUBMIT modal Registro (AJAX con FormData) === */
    var formRegistro = document.getElementById('formModalRegistro');
    if (formRegistro) {
        formRegistro.addEventListener('submit', function(e) {
            e.preventDefault();
            var errorDiv = document.getElementById('modalRegistroError');
            var errorMsg = document.getElementById('modalRegistroMsgError');
            var exitoDiv = document.getElementById('modalRegistroExito');
            var exitoMsg = document.getElementById('modalRegistroMsgExito');
            errorDiv.style.display = 'none';
            exitoDiv.style.display = 'none';

            var formData = new FormData(formRegistro);

            var xhr = new XMLHttpRequest();
            xhr.open('POST', 'RegistroController', true);
            xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
            xhr.onreadystatechange = function() {
                if (xhr.readyState === 4) {
                    if (xhr.status === 200) {
                        var data = JSON.parse(xhr.responseText);
                        if (data.resultado === 'ok') {
                            exitoMsg.textContent = 'Registro completado. Ya puedes acceder.';
                            exitoDiv.style.display = 'block';
                            errorDiv.style.display = 'none';
                            formRegistro.reset();
                            /* Restablecer preview avatar */
                            var mPrev = document.getElementById('m-avatarPreviewImg');
                            if (mPrev) { mPrev.src = mPrev.src.replace(/[^/]+$/, 'Otro.jpg'); }
                            /* Tras 2s cambiar a modal acceder */
                            setTimeout(function() {
                                cerrarModalRegistro();
                                abrirModalAcceder();
                            }, 2000);
                        } else if (data.resultado === 'error') {
                            errorMsg.textContent = data.mensaje;
                            errorDiv.style.display = 'block';
                            /* Scroll al mensaje de error */
                            errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    } else {
                        errorMsg.textContent = 'Error de conexi\u00f3n. Int\u00e9ntalo de nuevo.';
                        errorDiv.style.display = 'block';
                    }
                }
            };
            xhr.send(formData);
        });
    }
});

/* =========================== FUNCIONES MODALES =========================== */

function abrirModalAcceder() {
    var m = document.getElementById('modalAcceder');
    if (m) { m.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
}
function cerrarModalAcceder() {
    var m = document.getElementById('modalAcceder');
    if (m) {
        m.style.display = 'none';
        document.body.style.overflow = '';
        document.getElementById('modalAccederError').style.display = 'none';
    }
}
function abrirModalRegistro() {
    var m = document.getElementById('modalRegistro');
    if (m) { m.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
}
function cerrarModalRegistro() {
    var m = document.getElementById('modalRegistro');
    if (m) {
        m.style.display = 'none';
        document.body.style.overflow = '';
        document.getElementById('modalRegistroError').style.display = 'none';
        document.getElementById('modalRegistroExito').style.display = 'none';
    }
}

/* Previsualizar avatar del MODAL de registro */
function validarYPrevisualizarAvatarModal(input) {
    var preview = document.getElementById('m-avatarPreviewImg');
    var MAX_SIZE = 100 * 1024;
    var TIPOS_VALIDOS = ['image/jpeg', 'image/png'];
    if (!input.files || !input.files[0]) return;
    var archivo = input.files[0];
    if (TIPOS_VALIDOS.indexOf(archivo.type) === -1) {
        alert('Solo se permiten im\u00e1genes JPG o PNG.');
        input.value = '';
        return;
    }
    if (archivo.size > MAX_SIZE) {
        alert('La imagen no puede superar los 100 KB (tu archivo pesa ' + Math.round(archivo.size / 1024) + ' KB).');
        input.value = '';
        return;
    }
    if (preview) {
        var reader = new FileReader();
        reader.onload = function(e) { preview.src = e.target.result; };
        reader.readAsDataURL(archivo);
    }
    var radios = document.querySelectorAll('#formModalRegistro input[name="avatarPredefinido"]');
    for (var i = 0; i < radios.length; i++) { radios[i].checked = false; }
}

/* Cerrar modales con Escape y clic fuera */
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        var mAcc = document.getElementById('modalAcceder');
        var mReg = document.getElementById('modalRegistro');
        if (mAcc && mAcc.style.display === 'flex') cerrarModalAcceder();
        if (mReg && mReg.style.display === 'flex') cerrarModalRegistro();
    }
});
document.addEventListener('click', function(e) {
    if (e.target.id === 'modalAcceder') cerrarModalAcceder();
    if (e.target.id === 'modalRegistro') cerrarModalRegistro();
});
</script>
