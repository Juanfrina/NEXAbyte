<%-- ====== MODAL ACCEDER ====== --%>
<div id="modalAcceder" class="modal-overlay" style="display:none">
    <div class="modal-contenido modal-form formulario-contenedor formulario-estrecho">
        <button type="button" class="modal-cerrar" onclick="cerrarModalAcceder()" title="Cerrar">&times;</button>
        <h2 class="formulario-titulo">Acceder</h2>
        <div id="modalAccederError" class="alerta alerta-error" style="display:none">
            <span class="alerta-icono">&#9888;</span> <span id="modalAccederMsgError"></span>
        </div>
        <form id="formModalAcceder" class="formulario" novalidate autocomplete="off">
            <div class="formulario-grupo">
                <label for="m-login-email" class="formulario-etiqueta">Correo electr&oacute;nico</label>
                <input type="email" id="m-login-email" name="email" class="formulario-input"
                       placeholder="ejemplo@correo.com" required autocomplete="username"
                       title="Introduce tu correo electr&oacute;nico">
            </div>
            <div class="formulario-grupo">
                <label for="m-login-password" class="formulario-etiqueta">Contrase&ntilde;a</label>
                <div class="password-contenedor">
                    <input type="password" id="m-login-password" name="password" class="formulario-input"
                           placeholder="Tu contrase&ntilde;a" required autocomplete="current-password"
